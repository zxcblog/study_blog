#
# etcd 配置信息
#
ETCD1_PORT = 2379
ETCD1_80_PORT = 2381

ETCD2_PORT = 2389
ETCD2_80_PORT = 2382

ETCD3_PORT = 2399
ETCD3_80_PORT = 2383

ETCD_VERSION=3.5.9
ETCD1_YAML_FILE = ./services/etcd/conf/etcd1.yaml
ETCD1_DATA = ./services/etcd/data/data1
ETCD2_YAML_FILE = ./services/etcd/conf/etcd2.yaml
ETCD2_DATA = ./services/etcd/data/data2
ETCD3_YAML_FILE = ./services/etcd/conf/etcd3.yaml
ETCD3_DATA = ./services/etcd/data/data3
